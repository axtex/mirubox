generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  xp            Int       @default(0)
  level         Int       @default(1)
  tasteSummary  String?   @db.Text

  accounts       Account[]
  sessions       Session[]
  watchlist      WatchlistEntry[]
  ratings        Rating[]
  reviews        Review[]
  xpEvents       XpEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Anime {
  id           Int      @id
  title        String
  titleEnglish String?
  titleNative  String?
  description  String?  @db.Text
  coverImage   String?
  bannerImage  String?
  genres       String[]
  episodes     Int?
  chapters     Int?
  volumes      Int?
  status       String?
  season       String?
  seasonYear   Int?
  averageScore Int?
  popularity   Int?
  format       String?
  type         String   @default("ANIME")
  cachedAt     DateTime @default(now())
  embedding    Unsupported("vector(1536)")?

  watchlistEntries WatchlistEntry[]
  ratings          Rating[]
  reviews          Review[]
  xpEvents         XpEvent[]
}

model WatchlistEntry {
  id        String   @id @default(cuid())
  userId    String
  animeId   Int
  status    String   @default("PLANNED")
  mediaType String   @default("ANIME")
  progress  Int      @default(0)
  total     Int?
  favourite Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  animeId   Int
  score     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Review {
  id               String   @id @default(cuid())
  userId           String
  animeId          Int
  content          String   @db.Text
  containsSpoilers Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  animeId   Int?
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime? @relation(fields: [animeId], references: [id])
}
