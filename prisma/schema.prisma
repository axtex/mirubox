generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  totalXP       Int       @default(0)
  rank          String    @default("WATCHER")
  tasteSummary  String?   @db.Text

  username      String?   @unique
  displayName   String?
  avatarUrl     String?
  onboarded     Boolean   @default(false)
  pushToken     String? // stub for mobile push later

  accounts             Account[]
  sessions             Session[]
  trackerEntries       TrackerEntry[]
  ratings              Rating[]
  reviews              Review[]
  xpTransactions       XPTransaction[]
  userBadges           UserBadge[]
  userStreak           UserStreak?
  seasonalProgress     SeasonalProgress[]
  favourites           Favourite[]
  favouriteAnime       FavouriteAnime[]
  favouriteManga       FavouriteManga[]
  lists                List[]
  listLikes            ListLike[]
  notifications        Notification[] @relation("UserNotifications")
  notificationsTriggered Notification[] @relation("NotificationSender")
}

model List {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String?
  isOfficial  Boolean     @default(false)
  isPublic    Boolean     @default(true)
  userId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])
  entries     ListEntry[]
  likes       ListLike[]
  notifications Notification[]
}

model ListEntry {
  id        String   @id @default(cuid())
  listId    String
  mediaId   Int
  mediaType String
  order     Int      @default(0)
  note      String?
  addedAt   DateTime @default(now())
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, mediaId])
  @@index([listId, order])
}

model ListLike {
  userId    String
  listId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([userId, listId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Anime {
  id           Int      @id
  title        String
  titleEnglish String?
  titleNative  String?
  description  String?  @db.Text
  coverImage   String?
  bannerImage  String?
  genres       String[]
  episodes     Int?
  chapters     Int?
  volumes      Int?
  status       String?
  season       String?
  seasonYear   Int?
  averageScore Int?
  popularity   Int?
  format       String?
  type         String   @default("ANIME")
  demographic         String?
  hasAnimeAdaptation  Boolean  @default(false)
  isTop100            Boolean  @default(false)
  cachedAt     DateTime @default(now())
  embedding    Unsupported("vector(1536)")?

  trackerEntries   TrackerEntry[]
  ratings          Rating[]
  reviews          Review[]
  favourites       Favourite[]
  favouriteAnime   FavouriteAnime[]
  favouriteManga   FavouriteManga[]

  @@index([title])
  @@index([titleEnglish])
  @@index([popularity])
}

model TrackerEntry {
  id        String   @id @default(cuid())
  userId    String
  animeId   Int
  status    String   @default("PLANNED")
  mediaType String   @default("ANIME")
  progress  Int      @default(0)
  total     Int?
  favourite Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Rating {
  id                   String   @id @default(cuid())
  userId               String
  animeId              Int
  score                Float
  anilistScoreAtRating Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Review {
  id               String   @id @default(cuid())
  userId           String
  animeId          Int
  content          String   @db.Text
  containsSpoilers Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  mediaType String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [mediaId], references: [id])

  @@unique([userId, mediaId])
}

model FavouriteAnime {
  id      String @id @default(cuid())
  userId  String
  mediaId Int
  order   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  media   Anime  @relation(fields: [mediaId], references: [id])

  @@unique([userId, mediaId])
  @@index([userId, order])
}

model FavouriteManga {
  id      String @id @default(cuid())
  userId  String
  mediaId Int
  order   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  media   Anime  @relation(fields: [mediaId], references: [id])

  @@unique([userId, mediaId])
  @@index([userId, order])
}

model XPTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  action    XPAction
  mediaId   Int?
  listId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, action])
  @@index([userId, mediaId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeKey
  earnedAt  DateTime @default(now())
  xpAwarded Int      @default(0)

  @@unique([userId, badge])
  @@index([userId])
}

model UserStreak {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  loginStreak      Int       @default(0)
  lastLoginDate    DateTime?
}

model SeasonalProgress {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  season    String
  count     Int     @default(0)
  completed Boolean @default(false)

  @@unique([userId, season])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       NotifType
  title      String
  body       String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  listId     String?
  mediaId    Int?
  badgeKey   String?
  fromUserId String?

  user     User  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUser User? @relation("NotificationSender", fields: [fromUserId], references: [id], onDelete: SetNull)
  list     List? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model RateLimit {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

enum NotifType {
  BADGE_EARNED
  RANK_UP
  LIST_LIKED
  NEW_FOLLOWER
}

enum XPAction {
  ADD_TO_TRACKER
  MARK_IN_PROGRESS
  MARK_COMPLETED
  MARK_COMPLETED_DIRECT
  COMPLETE_MOVIE_OVA
  RATE_TITLE
  WRITE_REVIEW
  ADD_TO_LIST
  CREATE_LIST
  DAILY_LOGIN
  LOGIN_STREAK_7
  ADD_FRIEND
  INVITE_FRIEND
  FIRST_TITLE
  SEASON_CHALLENGE
  BADGE_UNLOCKED
}

enum BadgeKey {
  // Completion
  FIRST_FINISH
  SERIES_BINGER
  COMPLETIONIST
  CENTENARIAN
  CINEPHILE
  COMPLETIONIST_PLUS
  // Demographic enthusiast
  SHONEN_ENTHUSIAST
  SHOJO_ENTHUSIAST
  SEINEN_ENTHUSIAST
  JOSEI_ENTHUSIAST
  // Demographic veteran
  SHONEN_VETERAN
  SHOJO_VETERAN
  SEINEN_VETERAN
  JOSEI_VETERAN
  // Genre mastery
  MIND_BENT
  SLICE_OF_LIFER
  THE_ROMANTIC
  HORROR_HEAD
  SCI_FI_FAN
  FANTASY_DWELLER
  // Manga
  READER
  BOOKWORM
  STACKER
  ONE_AND_DONE
  READ_BEFORE_WATCH
  ORIGIN_SEEKER
  UP_TO_DATE
  // Critic
  FIRST_TAKE
  CRITIC
  STAFF_WRITER
  BIG_RATER
  DISCERNING
  // Streak
  ON_A_ROLL
  COMMITTED
  DEVOTED
  // Seasonal
  SPRING_WATCHER
  SUMMER_WATCHER
  FALL_WATCHER
  WINTER_WATCHER
  SEASONED_WATCHER
  // Explorer
  GENRE_EXPLORER
  HISTORIAN
  HIDDEN_GEM
  ALL_ROUNDER
  // Social
  RECRUITER
  AMBASSADOR
  LIST_MAKER
  WELL_LIKED
  // Prestige
  TOP_100
  PURIST
  CONTRARIAN
}
